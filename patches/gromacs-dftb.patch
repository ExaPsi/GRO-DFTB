+/*! \internal \file
+ * \brief
+ * Declares DFTB+ checkpoint state for QM/MM checkpointing
+ *
+ * \author GRO-DFTB developers
+ * \ingroup module_applied_forces
+ */
+#ifndef GMX_APPLIED_FORCES_DFTBCHECKPOINTSTATE_H
+#define GMX_APPLIED_FORCES_DFTBCHECKPOINTSTATE_H
+
+#include <string_view>
+#include <vector>
+
+namespace gmx
+{
+
+class KeyValueTreeObject;
+class KeyValueTreeObjectBuilder;
+
+/*! \internal
+ * \brief Class defining the internal DFTB+ checkpoint state for QM/MM.
+ *
+ * Stores Mulliken charges, inserted QM charges (for PME embedding),
+ * and boolean flags needed for checkpoint/restart of DFTB+ QM/MM simulations.
+ *
+ * ThDD:T-US-051-5.1 -- Checkpoint serialization
+ * ThDD:T-US-051-5.2 -- Checkpoint deserialization
+ * SDD:specs.md:section7 -- DFTBForceProvider checkpoint interface
+ */
+class DFTBCheckpointState
+{
+
+public:
+    //! Default constructor
+    DFTBCheckpointState() = default;
+
+    /*! \brief Write internal DFTB+ state into a key value tree.
+     * The entries to the kvt are identified with identifier, so that a variable
+     * is identified with the key "identifier-variablename"
+     *
+     * \param[in] kvtBuilder enables writing to the Key-Value-Tree
+     *                              the state is written to
+     *
+     * \param[in] identifier denotes the module that is checkpointing the data
+     */
+    void writeState(KeyValueTreeObjectBuilder kvtBuilder, std::string_view identifier) const;
+
+    /*! \brief Read the internal parameters from the checkpoint file on master
+     * \param[in] kvtData holding the checkpoint information
+     * \param[in] identifier identifies the data in a key-value-tree
+     */
+    void readState(const KeyValueTreeObject& kvtData, std::string_view identifier);
+
+    /*! \brief Returns whether a DFTB+ state was read from checkpoint.
+     * \return true if state was read, false otherwise
+     */
+    bool isStateRead() const { return stateRead_; }
+
+    /*! \brief Returns the stored Mulliken charges.
+     * \return reference to Mulliken charges vector
+     */
+    const std::vector<double>& mullikenCharges() const { return mullikenCharges_; }
+
+    /*! \brief Returns the stored inserted QM charges.
+     * \return reference to inserted QM charges vector
+     */
+    const std::vector<double>& insertedQmCharges() const { return insertedQmCharges_; }
+
+    /*! \brief Returns whether inserted charges have been populated.
+     * \return true if charges were inserted before checkpoint
+     */
+    bool haveInsertedCharges() const { return haveInsertedCharges_; }
+
+    /*! \brief Returns whether QM charges were in the PME array at checkpoint time.
+     * \return true if QM charges were present in GROMACS chargeA
+     */
+    bool qmChargesInPme() const { return qmChargesInPme_; }
+
+    /*! \brief Set the Mulliken charges for checkpointing.
+     * \param[in] charges Mulliken charges to store
+     */
+    void setMullikenCharges(const std::vector<double>& charges) { mullikenCharges_ = charges; }
+
+    /*! \brief Set the inserted QM charges for checkpointing.
+     * \param[in] charges inserted QM charges to store
+     */
+    void setInsertedQmCharges(const std::vector<double>& charges) { insertedQmCharges_ = charges; }
+
+    /*! \brief Set the haveInsertedCharges flag.
+     * \param[in] value whether inserted charges have been populated
+     */
+    void setHaveInsertedCharges(bool value) { haveInsertedCharges_ = value; }
+
+    /*! \brief Set the qmChargesInPme flag.
+     * \param[in] value whether QM charges are in the PME array
+     */
+    void setQmChargesInPme(bool value) { qmChargesInPme_ = value; }
+
+private:
+    /*! \brief Indicate if a DFTB+ state was read from checkpoint.
+     */
+    bool stateRead_ = false;
+
+    /*! \brief Mulliken charges from DFTB+ at checkpoint time.
+     *
+     * These are restored to seed the SCC iteration at restart,
+     * providing charge continuity across checkpoint boundaries.
+     */
+    std::vector<double> mullikenCharges_;
+
+    /*! \brief QM charges last inserted into GROMACS chargeA array.
+     *
+     * ThDD:T-US-047-N-1.1 -- Updated only at pair-search steps.
+     * Needed for exact energy/force double-counting corrections at restart.
+     */
+    std::vector<double> insertedQmCharges_;
+
+    /*! \brief Whether insertedQmCharges_ has been populated.
+     *
+     * False until the first QM charge insertion into PME (pair-search step).
+     */
+    bool haveInsertedCharges_ = false;
+
+    /*! \brief Whether QM charges were present in chargeA at checkpoint time.
+     *
+     * ThDD:T-US-047-4.2 -- Kernel transition flag.
+     * Determines whether the force provider uses the full Ewald path
+     * or the correction-only path at restart.
+     */
+    bool qmChargesInPme_ = false;
+};
+
+} // namespace gmx
+
+#endif // GMX_APPLIED_FORCES_DFTBCHECKPOINTSTATE_H
