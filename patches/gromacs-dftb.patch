+bool DFTBForceProvider::shouldRunConsistencyCheck(int64_t step) const
+{
+    /*
+     * ThDD:T-US-048-N-1.2 -- Check frequency strategy:
+     *   - First 100 steps: check at every pair-search step (cleanest: q_SCC = q_inserted)
+     *   - After step 100: check every 100 steps (to avoid log spam)
+     * SDD:specs.md:section8.2 -- Consistency requirement
+     */
+    const int nstlist = parameters_.nstlist_;
+    if (step < 100)
+    {
+        return (step % nstlist == 0);
+    }
+    else
+    {
+        return (step % 100 == 0);
+    }
+}
+
+void DFTBForceProvider::checkEmbeddingConsistency(int64_t step,
+                                                   double  energyHa,
+                                                   double  deltaEnergyHa) const
+{
+    /*
+     * ThDD:T-US-048-3.2 -- Relation 1: Embedding energy from potential
+     *   E_check = Sigma_{A=0}^{N_QM-1} q_A * Phi_damped(R_A)
+     *
+     * ThDD:T-US-048-4.1 -- This reconstructs the QM-MM interaction energy
+     * from the potential passed to DFTB+ as extpot. DFTB+ evaluated the same
+     * sum internally during SCC (Eq. T-US-048-2.3).
+     *
+     * Sign convention: pmePotentialBuf_[A] = -Phi_damped(R_A) (DFTB+ extpot,
+     * negated at line 1014). To get the physical embedding energy E = sum q*Phi,
+     * we negate: E_check = -sum q_A * pmePotentialBuf_[A].
+     *
+     * Units: [e] * [Ha/e] = [Ha]
+     */
+    double embeddingEnergyCheck = 0.0;
+    for (int a = 0; a < nQMAtoms_; a++)
+    {
+        embeddingEnergyCheck -= mullikenChargesBuf_[a] * pmePotentialBuf_[a];
+    }
+
+    /*
+     * ThDD:T-US-048-3.3 -- Relation 2: Correction self-consistency
+     *   DeltaE_check = -Sigma_A q^inserted_A * barePotentialBuf_[A]
+     *
+     * This must match deltaEnergyHa (computed in Step 10a) to machine precision
+     * since both use the same data and arithmetic.
+     *
+     * Tolerance: 10^{-12} Ha (Eq. T-US-048-5.4)
+     */
+    if (qmChargesInPme_ && haveInsertedCharges_)
+    {
+        double correctionCheck = 0.0;
+        for (int a = 0; a < nQMAtoms_; a++)
+        {
+            correctionCheck -= insertedQmCharges_[a] * barePotentialBuf_[a];
+        }
+        const double corrDiscrepancy = std::abs(correctionCheck - deltaEnergyHa);
+        if (corrDiscrepancy > 1e-12)
+        {
+            GMX_LOG(logger_.warning)
+                    .asParagraph()
+                    .appendTextFormatted(
+                            "Step %ld: Correction self-consistency FAILED: "
+                            "check=%.15e, computed=%.15e, diff=%.3e Ha",
+                            static_cast<long>(step),
+                            correctionCheck,
+                            deltaEnergyHa,
+                            corrDiscrepancy);
+        }
+    }
+
+    /*
+     * ThDD:T-US-048-4.3 -- Relation 3: Potential difference bounded
+     *   |Phi^bare[A] - Phi^damped[A]| < 0.1 Ha/e
+     *
+     * The difference is Sigma_J Q_J erfc(r_AJ/sigma)/r_AJ (Eq. T-US-048-2.6).
+     * This decays exponentially for r >> sigma and should be small.
+     *
+     * Sign convention: barePotentialBuf_[A] = +Phi_bare (physical),
+     * pmePotentialBuf_[A] = -Phi_damped (extpot convention).
+     * So: Phi_bare - Phi_damped = barePotentialBuf_ + pmePotentialBuf_
+     */
+    for (int a = 0; a < nQMAtoms_; a++)
+    {
+        const double diff = barePotentialBuf_[a] + pmePotentialBuf_[a];
+        if (std::abs(diff) > 0.1)
+        {
+            GMX_LOG(logger_.warning)
+                    .asParagraph()
+                    .appendTextFormatted(
+                            "Step %ld: Potential difference EXCEEDED 0.1 Ha/e at QM atom %d: "
+                            "Phi_bare=%.10e, Phi_damped=%.10e, diff=%.3e Ha/e",
+                            static_cast<long>(step),
+                            a,
+                            barePotentialBuf_[a],
+                            -pmePotentialBuf_[a],
+                            diff);
+        }
+    }
+
+    /*
+     * ThDD:T-US-048-4.1 -- Log summary
+     * Convert correction to kJ/mol for human readability.
+     * Units: Ha * c_hartree2Kj * c_avogadro = kJ/mol
+     */
+    const double totalCorrKjMol = deltaEnergyHa * c_hartree2Kj * c_avogadro;
+    GMX_LOG(logger_.info)
+            .asParagraph()
+            .appendTextFormatted(
+                    "Step %ld: E_embedding_check=%.10e Ha, "
+                    "E_correction=%.10e Ha (%.4f kJ/mol)",
+                    static_cast<long>(step),
+                    embeddingEnergyCheck,
+                    deltaEnergyHa,
+                    totalCorrKjMol);
+}
+
 } // namespace gmx
