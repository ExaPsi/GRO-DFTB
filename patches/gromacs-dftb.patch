+} // namespace
+
+/* ThDD:Eq. T-US-051-5.1 -- Serialize DFTB+ checkpoint state to KVT */
+void DFTBCheckpointState::writeState(KeyValueTreeObjectBuilder kvtBuilder,
+                                     std::string_view          identifier) const
+{
+    // Write Mulliken charges array
+    auto mullikenAdder =
+            kvtBuilder.addUniformArray<double>(std::string(identifier) + "-" + c_mullikenChargesTag_);
+    for (const auto& q : mullikenCharges_)
+    {
+        mullikenAdder.addValue(q);
+    }
+
+    // Write inserted QM charges array
+    auto insertedAdder = kvtBuilder.addUniformArray<double>(std::string(identifier) + "-"
+                                                            + c_insertedQmChargesTag_);
+    for (const auto& q : insertedQmCharges_)
+    {
+        insertedAdder.addValue(q);
+    }
+
+    // Write boolean flags as int (KVT does not natively support bool)
+    kvtBuilder.addValue<int>(std::string(identifier) + "-" + c_haveInsertedChargesTag_,
+                             static_cast<int>(haveInsertedCharges_));
+    kvtBuilder.addValue<int>(std::string(identifier) + "-" + c_qmChargesInPmeTag_,
+                             static_cast<int>(qmChargesInPme_));
+}
+
+/* ThDD:Eq. T-US-051-5.2 -- Restore DFTB+ checkpoint state from KVT */
+void DFTBCheckpointState::readState(const KeyValueTreeObject& kvtData, std::string_view identifier)
+{
+    const std::string mullikenKey = std::string(identifier) + "-" + c_mullikenChargesTag_;
+
+    // Check if DFTB+ checkpoint data exists (graceful legacy handling)
+    if (!kvtData.keyExists(mullikenKey))
+    {
+        stateRead_ = false;
+        return;
+    }
+
+    stateRead_ = true;
+
+    // Read Mulliken charges array
+    {
+        auto kvtDoubleArray = kvtData[mullikenKey].asArray().values();
+        mullikenCharges_.resize(kvtDoubleArray.size());
+        for (size_t i = 0; i < kvtDoubleArray.size(); i++)
+        {
+            mullikenCharges_[i] = kvtDoubleArray[i].cast<double>();
+        }
+    }
+
+    // Read inserted QM charges array
+    const std::string insertedKey = std::string(identifier) + "-" + c_insertedQmChargesTag_;
+    if (kvtData.keyExists(insertedKey))
+    {
+        auto kvtDoubleArray = kvtData[insertedKey].asArray().values();
+        insertedQmCharges_.resize(kvtDoubleArray.size());
+        for (size_t i = 0; i < kvtDoubleArray.size(); i++)
+        {
+            insertedQmCharges_[i] = kvtDoubleArray[i].cast<double>();
+        }
+    }
+
+    // Read haveInsertedCharges flag
+    const std::string haveInsertedKey = std::string(identifier) + "-" + c_haveInsertedChargesTag_;
+    if (kvtData.keyExists(haveInsertedKey))
+    {
+        haveInsertedCharges_ = (kvtData[haveInsertedKey].cast<int>() != 0);
+    }
+
+    // Read qmChargesInPme flag
+    const std::string qmInPmeKey = std::string(identifier) + "-" + c_qmChargesInPmeTag_;
+    if (kvtData.keyExists(qmInPmeKey))
+    {
+        qmChargesInPme_ = (kvtData[qmInPmeKey].cast<int>() != 0);
+    }
+}
+
+} // namespace gmx
