+/*! \internal \file
+ * \brief
+ * Tests for DFTBCheckpointState class used for DFTB+ QM/MM checkpointing.
+ *
+ * \author GRO-DFTB developers
+ * \ingroup module_applied_forces
+ */
+#include "gmxpre.h"
+
+#include "gromacs/applied_forces/qmmm/dftbcheckpointstate.h"
+
+#include <gtest/gtest.h>
+
+#include "gromacs/utility/keyvaluetree.h"
+#include "gromacs/utility/keyvaluetreebuilder.h"
+
+namespace gmx
+{
+
+class DFTBCheckpointStateTest : public ::testing::Test
+{
+protected:
+    //! Identifier for DFTB+ checkpoint keys (distinct from CP2K "qmmm-cp2k")
+    static constexpr const char* sc_identifier_ = "qmmm-dftb";
+
+    //! Test Mulliken charges for a B5-like water (O, H, H)
+    std::vector<double> defaultCharges_ = { -0.636, 0.318, 0.318 };
+};
+
+// AC-1: Mulliken charges survive write->read roundtrip with exact bitwise match
+TEST_F(DFTBCheckpointStateTest, RoundtripMullikenCharges)
+{
+    DFTBCheckpointState writeState;
+    writeState.setMullikenCharges(defaultCharges_);
+
+    KeyValueTreeBuilder builder;
+    writeState.writeState(builder.rootObject(), sc_identifier_);
+    const KeyValueTreeObject kvt = builder.build();
+
+    DFTBCheckpointState readState;
+    readState.readState(kvt, sc_identifier_);
+
+    EXPECT_TRUE(readState.isStateRead());
+    const auto& readCharges = readState.mullikenCharges();
+    ASSERT_EQ(defaultCharges_.size(), readCharges.size());
+    for (size_t i = 0; i < defaultCharges_.size(); i++)
+    {
+        EXPECT_DOUBLE_EQ(defaultCharges_[i], readCharges[i]);
+    }
+}
+
+// AC-1b: Edge case with all-zero charges (step 0 scenario)
+TEST_F(DFTBCheckpointStateTest, RoundtripZeroCharges)
+{
+    std::vector<double> zeroCharges = { 0.0, 0.0, 0.0 };
+
+    DFTBCheckpointState writeState;
+    writeState.setMullikenCharges(zeroCharges);
+
+    KeyValueTreeBuilder builder;
+    writeState.writeState(builder.rootObject(), sc_identifier_);
+    const KeyValueTreeObject kvt = builder.build();
+
+    DFTBCheckpointState readState;
+    readState.readState(kvt, sc_identifier_);
+
+    EXPECT_TRUE(readState.isStateRead());
+    const auto& readCharges = readState.mullikenCharges();
+    ASSERT_EQ(zeroCharges.size(), readCharges.size());
+    for (size_t i = 0; i < zeroCharges.size(); i++)
+    {
+        EXPECT_DOUBLE_EQ(zeroCharges[i], readCharges[i]);
+    }
+}
+
+// AC-1c: Link atom case where Mulliken and inserted charge arrays have different sizes
+TEST_F(DFTBCheckpointStateTest, MismatchedArraySizes)
+{
+    std::vector<double> mullikenCharges  = { -0.636, 0.318, 0.318, -0.1, 0.05 };
+    std::vector<double> insertedCharges  = { -0.636, 0.318, 0.318 };
+
+    DFTBCheckpointState writeState;
+    writeState.setMullikenCharges(mullikenCharges);
+    writeState.setInsertedQmCharges(insertedCharges);
+    writeState.setHaveInsertedCharges(true);
+
+    KeyValueTreeBuilder builder;
+    writeState.writeState(builder.rootObject(), sc_identifier_);
+    const KeyValueTreeObject kvt = builder.build();
+
+    DFTBCheckpointState readState;
+    readState.readState(kvt, sc_identifier_);
+
+    EXPECT_TRUE(readState.isStateRead());
+
+    const auto& readMulliken = readState.mullikenCharges();
+    ASSERT_EQ(mullikenCharges.size(), readMulliken.size());
+    for (size_t i = 0; i < mullikenCharges.size(); i++)
+    {
+        EXPECT_DOUBLE_EQ(mullikenCharges[i], readMulliken[i]);
+    }
+
+    const auto& readInserted = readState.insertedQmCharges();
+    ASSERT_EQ(insertedCharges.size(), readInserted.size());
+    for (size_t i = 0; i < insertedCharges.size(); i++)
+    {
+        EXPECT_DOUBLE_EQ(insertedCharges[i], readInserted[i]);
+    }
+}
+
+// AC-2: All 4 fields (both charge arrays + both flags) survive write->read
+TEST_F(DFTBCheckpointStateTest, FullStateRestoration)
+{
+    DFTBCheckpointState writeState;
+    writeState.setMullikenCharges(defaultCharges_);
+    writeState.setInsertedQmCharges({ -0.640, 0.320, 0.320 });
+    writeState.setHaveInsertedCharges(true);
+    writeState.setQmChargesInPme(true);
+
+    KeyValueTreeBuilder builder;
+    writeState.writeState(builder.rootObject(), sc_identifier_);
+    const KeyValueTreeObject kvt = builder.build();
+
+    DFTBCheckpointState readState;
+    readState.readState(kvt, sc_identifier_);
+
+    EXPECT_TRUE(readState.isStateRead());
+
+    // Verify Mulliken charges
+    const auto& readMulliken = readState.mullikenCharges();
+    ASSERT_EQ(defaultCharges_.size(), readMulliken.size());
+    for (size_t i = 0; i < defaultCharges_.size(); i++)
+    {
+        EXPECT_DOUBLE_EQ(defaultCharges_[i], readMulliken[i]);
+    }
+
+    // Verify inserted QM charges
+    const auto& readInserted = readState.insertedQmCharges();
+    ASSERT_EQ(3U, readInserted.size());
+    EXPECT_DOUBLE_EQ(-0.640, readInserted[0]);
+    EXPECT_DOUBLE_EQ(0.320, readInserted[1]);
+    EXPECT_DOUBLE_EQ(0.320, readInserted[2]);
+
+    // Verify flags
+    EXPECT_TRUE(readState.haveInsertedCharges());
+    EXPECT_TRUE(readState.qmChargesInPme());
+}
+
+// AC-3: insertedQmCharges survives write->read cycle
+TEST_F(DFTBCheckpointStateTest, PmeChargesRoundtrip)
+{
+    DFTBCheckpointState writeState;
+    writeState.setMullikenCharges(defaultCharges_);
+    writeState.setInsertedQmCharges(defaultCharges_);
+    writeState.setHaveInsertedCharges(true);
+
+    KeyValueTreeBuilder builder;
+    writeState.writeState(builder.rootObject(), sc_identifier_);
+    const KeyValueTreeObject kvt = builder.build();
+
+    DFTBCheckpointState readState;
+    readState.readState(kvt, sc_identifier_);
+
+    EXPECT_TRUE(readState.isStateRead());
+    const auto& readInserted = readState.insertedQmCharges();
+    ASSERT_EQ(defaultCharges_.size(), readInserted.size());
+    for (size_t i = 0; i < defaultCharges_.size(); i++)
+    {
+        EXPECT_DOUBLE_EQ(defaultCharges_[i], readInserted[i]);
+    }
+}
+
+// AC-4: All 4 boolean flag combinations survive roundtrip
+TEST_F(DFTBCheckpointStateTest, FlagCombinations)
+{
+    const bool flagValues[4][2] = {
+        { false, false },
+        { false, true },
+        { true, false },
+        { true, true },
+    };
+
+    for (const auto& flags : flagValues)
+    {
+        const bool haveInserted    = flags[0];
+        const bool qmChargesInPme = flags[1];
+
+        DFTBCheckpointState writeState;
+        writeState.setMullikenCharges(defaultCharges_);
+        writeState.setHaveInsertedCharges(haveInserted);
+        writeState.setQmChargesInPme(qmChargesInPme);
+
+        KeyValueTreeBuilder builder;
+        writeState.writeState(builder.rootObject(), sc_identifier_);
+        const KeyValueTreeObject kvt = builder.build();
+
+        DFTBCheckpointState readState;
+        readState.readState(kvt, sc_identifier_);
+
+        EXPECT_TRUE(readState.isStateRead())
+                << "haveInserted=" << haveInserted << " qmChargesInPme=" << qmChargesInPme;
+        EXPECT_EQ(haveInserted, readState.haveInsertedCharges())
+                << "haveInserted mismatch for (" << haveInserted << "," << qmChargesInPme << ")";
+        EXPECT_EQ(qmChargesInPme, readState.qmChargesInPme())
+                << "qmChargesInPme mismatch for (" << haveInserted << "," << qmChargesInPme << ")";
+    }
+}
+
+// Graceful handling of empty KVT (old checkpoint without DFTB+ data)
+TEST_F(DFTBCheckpointStateTest, MissingKeysDoNotCrash)
+{
+    KeyValueTreeBuilder    builder;
+    const KeyValueTreeObject kvt = builder.build();
+
+    DFTBCheckpointState readState;
+    readState.readState(kvt, sc_identifier_);
+
+    EXPECT_FALSE(readState.isStateRead());
+    EXPECT_TRUE(readState.mullikenCharges().empty());
+    EXPECT_TRUE(readState.insertedQmCharges().empty());
+    EXPECT_FALSE(readState.haveInsertedCharges());
+    EXPECT_FALSE(readState.qmChargesInPme());
+}
+
+// Option B: writeState preserves (true,true) flags faithfully in KVT.
+// The Option B reset (setting flags to false) happens in DFTBForceProvider
+// constructor, NOT in readState. This test verifies serialization fidelity.
+TEST_F(DFTBCheckpointStateTest, OptionBFlagsPreservedInSerialization)
+{
+    DFTBCheckpointState writeState;
+    writeState.setMullikenCharges(defaultCharges_);
+    writeState.setHaveInsertedCharges(true);
+    writeState.setQmChargesInPme(true);
+
+    KeyValueTreeBuilder builder;
+    writeState.writeState(builder.rootObject(), sc_identifier_);
+    const KeyValueTreeObject kvt = builder.build();
+
+    DFTBCheckpointState readState;
+    readState.readState(kvt, sc_identifier_);
+
+    // readState faithfully reads what was written
+    EXPECT_TRUE(readState.isStateRead());
+    EXPECT_TRUE(readState.haveInsertedCharges());
+    EXPECT_TRUE(readState.qmChargesInPme());
+}
+
+// AC-6: No crashes in 100 write/read cycles (leak detection via Valgrind is separate)
+TEST_F(DFTBCheckpointStateTest, RepeatedWriteReadCycles)
+{
+    for (int cycle = 0; cycle < 100; cycle++)
+    {
+        DFTBCheckpointState writeState;
+        writeState.setMullikenCharges(defaultCharges_);
+        writeState.setInsertedQmCharges(defaultCharges_);
+        writeState.setHaveInsertedCharges(true);
+        writeState.setQmChargesInPme(cycle % 2 == 0);
+
+        KeyValueTreeBuilder builder;
+        writeState.writeState(builder.rootObject(), sc_identifier_);
+        const KeyValueTreeObject kvt = builder.build();
+
+        DFTBCheckpointState readState;
+        readState.readState(kvt, sc_identifier_);
+
+        ASSERT_TRUE(readState.isStateRead()) << "Failed at cycle " << cycle;
+        ASSERT_EQ(defaultCharges_.size(), readState.mullikenCharges().size())
+                << "Mulliken size mismatch at cycle " << cycle;
+    }
+}
+
+} // namespace gmx
