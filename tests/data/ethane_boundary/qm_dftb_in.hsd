###############################################################################
# DFTB+ input for ethane QM region (methyl cap) for FD validation tests
# US-035: Charge redistribution chain-rule force validation
#
# QM region: CH3 (4 atoms: 1 C + 3 H)
# This is used with electrostatic embedding for FD tests of chain-rule forces.
#
# ThDD:T-US-035-V.4 -- Tight SCC tolerance for FD test accuracy
###############################################################################

Geometry = xyzFormat {
<<< "qm_geometry.xyz"
}

Driver = {}

Hamiltonian = DFTB {
    SCC = Yes
    SCCTolerance = 1e-10
    MaxSCCIterations = 100
    Mixer = Broyden {}
    Charge = 0

    SlaterKosterFiles = Type2FileNames {
        Prefix = "../slako/mio-1-1/"
        Separator = "-"
        Suffix = ".skf"
    }

    MaxAngularMomentum = {
        C = "p"
        H = "s"
    }

    Filling = Fermi {
        Temperature [Kelvin] = 0.0
    }
}

Options = {
    WriteAutotestTag = Yes
}

Analysis = {
    PrintForces = Yes
}

ParserOptions = {
    ParserVersion = 14
}
