# B6 Alanine Fragment Optimization
# System: 12-atom capped alanine fragment  H-NH-CH(CH3)-CHO
# All coordinates in Angstroms
#
# Atom order (matches test requirements):
# 0: N (QM boundary for link 1)
# 1: H (on N)
# 2: C (alpha carbon)
# 3: H (on C-alpha)
# 4: C (beta carbon, methyl)
# 5: H (methyl H1)
# 6: H (methyl H2)
# 7: H (methyl H3)
# 8: C (carbonyl carbon, QM boundary for link 2)
# 9: O (carbonyl oxygen)
# 10: H (link atom 1, capping N)
# 11: H (link atom 2, capping carbonyl C - aldehyde H)
#
# Species order: C=1, N=2, O=3, H=4

Geometry = GenFormat {
  12 C
  C  N  O  H
  # Building molecule step by step (Angstroms):
  # Start with N at origin, build along +x axis
  #
  # N-Calpha bond along +x, tetrahedral geometry
  # Calpha-Cbeta and Calpha-Ccarbonyl from Calpha
  #
  1   2    0.000    0.000    0.000      # N
  2   4    0.000    0.940    0.270      # H on N
  3   1    1.470    0.000    0.000      # C-alpha
  4   4    1.470   -1.090    0.000      # H on C-alpha
  5   1    2.100    0.600    1.300      # C-beta (methyl)
  6   4    3.180    0.450    1.400      # methyl H1
  7   4    1.600    0.100    2.130      # methyl H2
  8   4    1.850    1.660    1.350      # methyl H3
  9   1    2.100    0.600   -1.300      # carbonyl C
  10  3    3.020    1.350   -1.600      # carbonyl O (C=O)
  11  4   -1.010    0.000    0.000      # link H1 (capping N along -x)
  12  4    1.850   -0.050   -2.130      # link H2 (aldehyde H)
}

Driver = GeometryOptimization {
  Optimizer = Rational {}
  MovedAtoms = 1:-1
  MaxSteps = 200
  OutputPrefix = "geom.out"
  Convergence {
    GradElem = 1e-5
    GradNorm = 1e-4
    DispElem = 1e-5
    DispNorm = 1e-4
    Energy = 1e-8
  }
}

Hamiltonian = DFTB {
  SCC = Yes
  SCCTolerance = 1e-8
  MaxSCCIterations = 200

  SlaterKosterFiles = Type2FileNames {
    Prefix = "../../slako/mio-1-1/"
    Separator = "-"
    Suffix = ".skf"
  }

  MaxAngularMomentum {
    C = "p"
    N = "p"
    O = "p"
    H = "s"
  }

  Filling = Fermi {
    Temperature [Kelvin] = 0.0
  }
}

Analysis {
  MullikenAnalysis = Yes
}

Options {
  WriteDetailedOut = Yes
}

ParserOptions {
  ParserVersion = 14
}
