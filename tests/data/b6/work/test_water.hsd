# Test: Water molecule - verify DFTB+ works with mio-1-1
# Geometry in Angstroms (default GenFormat unit)

Geometry = GenFormat {
  3 C
  O  H
  1   1    0.000   0.000   0.117
  2   2    0.000   0.757  -0.468
  3   2    0.000  -0.757  -0.468
}

Driver = {}

Hamiltonian = DFTB {
  SCC = Yes
  SCCTolerance = 1e-8
  MaxSCCIterations = 100

  SlaterKosterFiles = Type2FileNames {
    Prefix = "../../slako/mio-1-1/"
    Separator = "-"
    Suffix = ".skf"
  }

  MaxAngularMomentum {
    O = "p"
    H = "s"
  }

  Filling = Fermi {
    Temperature [Kelvin] = 0.0
  }
}

Analysis {
  MullikenAnalysis = Yes
}

Options {
  WriteDetailedOut = Yes
}

ParserOptions {
  ParserVersion = 14
}
