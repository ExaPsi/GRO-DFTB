Driver = {}

Hamiltonian = DFTB {
  SCC = Yes
  SCCTolerance = 1e-10
  MaxSCCIterations = 200

  SlaterKosterFiles = Type2FileNames {
    Prefix = "../../slako/mio-1-1/"
    Separator = "-"
    Suffix = ".skf"
  }

  MaxAngularMomentum {
    C = "p"
    N = "p"
    O = "p"
    H = "s"
  }

  Filling = Fermi {
    Temperature [Kelvin] = 0.0
  }
}

Analysis {
  MullikenAnalysis = Yes
}

Options {
  WriteDetailedOut = Yes
}

ParserOptions {
  ParserVersion = 14
}
