Geometry = GenFormat {
  <<< "geo.gen"
}

Driver = {}

Hamiltonian = DFTB {
  SCC = Yes
  SCCTolerance = 1.0e-10
  MaxSCCIterations = 100
  Mixer = Broyden {}
  Charge = 0
  ThirdOrderFull = Yes
  HubbardDerivs {
    O = -0.1575
    H = -0.1857
  }
  MaxAngularMomentum = {
    O = "p"
    H = "s"
  }
  Filling = Fermi {
    Temperature [Kelvin] = 0.0
  }
  SlaterKosterFiles = Type2FileNames {
    Prefix = "../slako/3ob-3-1/"
    Separator = "-"
    Suffix = ".skf"
  }
}

Options = {
  WriteDetailedOut = No
}

ParserOptions = {
  ParserVersion = 14
}
