; B6 Solvated NVE: Alanine dipeptide QM/MM with PME embedding
; 100 ps production run (0.5 fs timestep, 200000 steps)
; QM region: 10 ALA atoms + 2 link H = 12 augmented
; PME embedding: full periodic electrostatics

; Run parameters
integrator               = md
nsteps                   = 200000    ; 100 ps
dt                       = 0.0005    ; 0.5 fs

; Continue from NVT equilibration
continuation             = yes
gen-vel                  = no

; Output control
nstxout                  = 0
nstvout                  = 0
nstfout                  = 0
nstenergy                = 10        ; every 5 fs
nstlog                   = 100       ; every 50 fs
nstxout-compressed       = 1000      ; every 0.5 ps
compressed-x-precision   = 100

; Neighbor searching
cutoff-scheme            = Verlet
nstlist                  = 10
pbc                      = xyz
verlet-buffer-tolerance  = 0.005

; Electrostatics
coulombtype              = PME
rcoulomb                 = 1.0
pme-order                = 4
fourierspacing           = 0.12

; Van der Waals
vdwtype                  = Cut-off
rvdw                     = 1.0
DispCorr                 = EnerPres

; Temperature coupling (NVE - DISABLED)
tcoupl                   = no

; Pressure coupling (NVE - DISABLED)
pcoupl                   = no

; Constraints
constraints              = h-bonds
constraint-algorithm     = LINCS
lincs-order              = 4
lincs-iter               = 1

; QM/MM with DFTB+
qmmm-cp2k-active              = yes
qmmm-cp2k-qmgroup             = QMMM
qmmm-cp2k-qmmethod            = DFTBPLUS
qmmm-cp2k-qmcharge            = 0
qmmm-cp2k-qmmultiplicity      = 1
qmmm-cp2k-dftbplus-hsd        = dftb_in.hsd
qmmm-cp2k-dftbplus-embedding  = PME
qmmm-cp2k-dftbplus-cutoff     = 1.0
qmmm-cp2k-dftbplus-switch-width = 0.0
qmmm-cp2k-dftbplus-damping-sigma = 0.1
qmmm-cp2k-dftbplus-charge-redistribution = NONE
