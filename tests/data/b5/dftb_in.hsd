# DFTB+ HSD for B5 Benchmark (DFTB2/mio-1-1)
# System: 1 QM water molecule
# Method: DFTB2 (SCC-DFTB, second-order)
# SK Set: mio-1-1
#
# SCC robustness notes (US-043 root cause analysis):
#   - Anderson mixer is more robust than Broyden for QM/MM with
#     large external potential perturbations. Broyden builds a quasi-Newton
#     Jacobian that can become corrupted when charges jump discontinuously.
#   - Fermi Temperature > 0 smooths the occupation function, preventing
#     discontinuous charge jumps when eigenvalues cross the Fermi level.
#     100 K = 3.167e-6 Hartree, negligible for a gapped system like water.
#   - ConvergentSCCOnly = No prevents Fortran ERROR STOP on rare
#     non-convergence events; the caller (GRO-DFTB) handles the policy.
#   - ForceEvaluation = "dynamics" includes Pulay-correction terms for
#     energy-conserving dynamics with finite-temperature filling.

Geometry = GenFormat {
  <<< "qm_water_isolated.gen"
}

Hamiltonian = DFTB {
  SCC = Yes
  SCCTolerance = 1e-10
  MaxSCCIterations = 500
  ReadInitialCharges = No
  ConvergentSCCOnly = No

  SlaterKosterFiles = Type2FileNames {
    Prefix = "../slako/mio-1-1/"
    Separator = "-"
    Suffix = ".skf"
  }

  MaxAngularMomentum = {
    O = "p"
    H = "s"
  }

  Mixer = Anderson {
    MixingParameter = 0.05
    Generations = 8
    InitMixingParameter = 0.01
  }

  Filling = Fermi {
    Temperature [K] = 100.0
  }

  ForceEvaluation = "dynamics"
}

Options = {
  WriteDetailedOut = Yes
  WriteResultsTag = Yes
}

Analysis = {
  PrintForces = Yes
}

ParserOptions = {
  ParserVersion = 14
  IgnoreUnprocessedNodes = No
}
