Geometry = GenFormat {
  <<< "geo.gen"
}

Driver = {}

Hamiltonian = DFTB {
  SCC = Yes
  SCCTolerance = 1.0e-10
  MaxSCCIterations = 100
  Mixer = Broyden {}
  Charge = 0
  MaxAngularMomentum = {
    O = "p"
    H = "s"
  }
  Filling = Fermi {
    Temperature [Kelvin] = 0.0
  }
  SlaterKosterFiles = Type2FileNames {
    Prefix = "../slako/mio-1-1/"
    Separator = "-"
    Suffix = ".skf"
  }
  ElectricField = {
    PointCharges = {
      CoordsAndCharges [Angstrom] = {
       -3.000000  0.000000  0.000000  1.0
      }
    }
  }
}

Options = {
  WriteAutotestTag = Yes
}

Analysis = {
  PrintForces = Yes
}

ParserOptions = {
  ParserVersion = 14
}
