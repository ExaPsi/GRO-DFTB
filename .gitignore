# =============================================================================
*.xvg
*.edr
*.trr
*.xtc
*.gro
*.cpt
*.tpr
# Allow test data and benchmark files
!tests/data/**
!benchmarks/**

# =============================================================================
# DFTB+ Specific
# =============================================================================
# Output files
*.out
*.log
dftb_in.hsd
dftb_pin.hsd
# Allow test data input files
!tests/data/**/dftb_in.hsd
charges.bin
charges.dat
detailed.out
detailed.xml
results.tag
band.out
eigenvec.bin
eigenvec.out
md.out
geo_end.gen
geo_end.xyz

# Restart files
*.restart
restart.bin

# =============================================================================
# GROMACS Specific
# =============================================================================
# Trajectory and structure files
*.trr
*.xtc
*.tng
*.gro
!tests/data/**/*.gro
*.pdb
!tests/data/**/*.pdb
*.g96

# Energy and log files
*.edr
*.cpt
*.tpr
*.mdp
!tests/data/**/*.mdp
*.ndx
!tests/data/**/*.ndx

# Topology files (keep reference ones in tests/data)
*.top
!tests/data/**/*.top
*.itp
!tests/data/**/*.itp

# GROMACS backup files
\#*\#

# =============================================================================
# Slater-Koster Parameter Files
# =============================================================================
# Large SK files should not be tracked (use submodule or download script)
*.skf
!tests/data/**/*.skf
slakos/

# =============================================================================
# Test and Benchmark Outputs
# =============================================================================
tests/output/
tests/tmp/
tests/**/output/
benchmarks/results/
benchmarks/output/
*.benchmark.json

