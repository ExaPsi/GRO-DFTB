# =============================================================================
# GRO-DFTB .gitignore
# GROMACS-DFTB+ QM/MM Interface Project
# =============================================================================

# =============================================================================
# Build Directories
# =============================================================================
build/
build-*/
_build/
_build_*/
cmake-build-*/
out/

# =============================================================================
# CMake Generated Files
# =============================================================================
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CMakeDoxyfile.in
CMakeDoxygenDefaults.cmake
Makefile
*.cmake
!CMakeLists.txt
!/cmake/*.cmake
!cmake/Modules/*.cmake

# =============================================================================
