# =============================================================================
docs/_build/
docs/api/generated/
docs/html/
docs/latex/
docs/xml/
*.aux
*.log
*.out
*.toc
*.lof
*.lot
*.fls
*.fdb_latexmk
*.synctex.gz

# Doxygen
docs/doxygen/html/
docs/doxygen/latex/
docs/doxygen/xml/
doxygen_*.tmp

# Sphinx
docs/sphinx/_build/

# =============================================================================
# Container and CI/CD
# =============================================================================
*.tar
*.tar.gz
*.tar.bz2
*.zip
*.docker
.docker/

# =============================================================================
# Profiling and Debugging
# =============================================================================
*.prof
*.gcda
*.gcno
*.gcov
gmon.out
callgrind.out.*
cachegrind.out.*
massif.out.*
perf.data
perf.data.old

# Valgrind
vgcore.*

# Core dumps
core
core.*

# =============================================================================
# Package Managers
# =============================================================================
# Conan
conan.lock
conanbuildinfo.*
conaninfo.txt
graph_info.json

# vcpkg
vcpkg_installed/

# =============================================================================
# Miscellaneous
# =============================================================================
*.bak
*.backup
*.orig
*.tmp
*.temp
*~
.cache/
.ccache/
compile_commands.json
.clangd/
.task-master/

# =============================================================================
# Project-Specific Ignores
# =============================================================================
# Scratch and temporary work (should never exist at root per CLAUDE.md rules)
scratch/
tmp/
temp/

# Large external dependencies that should be fetched, not committed
# (external/ is tracked but large binaries within should be ignored)
external/dftbplus/build/
external/dftbplus/_build/
external/gromacs/build/
external/gromacs/_build/

# User-specific configuration
.env
.env.local
*.local

# =============================================================================
# Manuscript (tracked in separate local git repo)
# =============================================================================
docs/Manuscript/

# =============================================================================
# End of .gitignore
# =============================================================================
external/_install_dftb/
