.idea/
*.iml
*.iws
*.ipr

# Visual Studio
.vs/
*.vcxproj.user
*.suo
*.sln.docstates

# Eclipse
.project
.cproject
.settings/

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim/Neovim
*.swp
*.swo
*~
.netrwhist
tags
TAGS

# Emacs
*~
\#*\#
.#*
*.elc

# =============================================================================
