# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory
.Trash-*

# =============================================================================
# Python (build tools, dptools, test scripts)
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
dist/
eggs/
.eggs/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt
.Python
.python-version
.venv/
venv/
ENV/
env/
.tox/
.nox/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
.pytype/
.ipynb_checkpoints/

