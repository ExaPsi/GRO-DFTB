# =============================================================================
*.o
*.obj
*.a
*.so
*.so.*
*.dylib
*.lib
*.dll
*.exe
*.mod
*.smod

# =============================================================================
# Fortran Specific
# =============================================================================
*.mod
*.smod
*.f90~
*.F90~

# =============================================================================
# C/C++ Specific
# =============================================================================
*.d
*.pch
*.gch
*.lo
*.la
*.lai
*.Plo

# =============================================================================
